                            {# Include the event form partial we created earlier #}
                            {{ include('event/_form.html.twig', {'button_label': 'Save Event'}) }}
                            
                            <div class="mt-4">
                                <a href="{{ path('app_event_index') }}" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left"></i> Back to List
